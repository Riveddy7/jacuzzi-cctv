<section class="avia_codeblock_section  avia_code_block_19"  itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_codeblock '  itemprop="text" ><style >div#techpartners {
    border: none !important;
}
.logo-slider {
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    width: 100%;
    background: #fff;
    padding: 15px 0; /* Adjust padding for better spacing */
}

.logo-track {
    display: flex;
    align-items: center; /* Keeps logos aligned */
    gap: 60px; /* Reduce space between logos */
    animation: scroll 80s linear infinite;
    width: max-content;
}

.logo-track img {
    height: 80px; /* Reduced height for smaller logos */
    width: auto; /* Maintain aspect ratio */
    max-width: 130px; /* Prevent logos from being too large */
    display: inline-block;
    object-fit: contain; /* Ensures full image is visible */

}

@keyframes scroll {
    from {
        transform: translateX(0);
    }
    to {
        transform: translateX(-50%);
    }
}</style></div></section>
