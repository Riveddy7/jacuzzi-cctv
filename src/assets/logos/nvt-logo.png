<!-- Sebs UTM Script - session based -->
<script>
document.addEventListener("DOMContentLoaded", function () {
  // Get LP_Source from og:url
  const ogUrlTag = document.querySelector('meta[property="og:url"]');
  let lpSourceValue = "unknown";
  if (ogUrlTag) {
    const fullUrl = ogUrlTag.getAttribute("content") || "";
    lpSourceValue = fullUrl.replace("https://www.nvtphybridge.com", "") || "/";
  }

  // Read current page query params
  const pageUrl = new URL(window.location.href);
  const pageParams = new URLSearchParams(pageUrl.search);

  // Load any previously stored params for this session
  let storedParamMap = {};
  try {
    const stored = sessionStorage.getItem("seb_query_params");
    if (stored) {
      storedParamMap = JSON.parse(stored) || {};
    }
  } catch (e) {
    storedParamMap = {};
  }

  // Merge current page params into storedParamMap
  // Current page values win
  for (const [key, value] of pageParams.entries()) {
    if (key.toLowerCase() === "gclid") {
      storedParamMap["GCLID"] = value;
    } else {
      storedParamMap[key] = value;
    }
  }

  // Persist merged params for the rest of the session
  try {
    sessionStorage.setItem("seb_query_params", JSON.stringify(storedParamMap));
  } catch (e) {
    // If storage fails, do nothing and continue
  }

  // Build the param map to apply to links
  const pageParamMap = Object.assign({}, storedParamMap);
  pageParamMap["LP_Source"] = lpSourceValue;

  // Apply params to all relevant links
  document.querySelectorAll('a[href^="https://www2."]').forEach(function (link) {
    try {
      const url = new URL(link.href);
      const linkParams = url.searchParams;

      // Only add each param if it does not already exist in the link URL
      for (const [key, value] of Object.entries(pageParamMap)) {
        if (!linkParams.has(key)) {
          linkParams.append(key, value);
        }
      }

      link.href = url.toString();
    } catch (e) {
      // Ignore malformed URLs
    }
  });
});
</script>



