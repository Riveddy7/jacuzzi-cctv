					div[id*='ajaxsearchlite'].asl_r .results {
						max-height: none;
					}
					div[id*='ajaxsearchlite'].asl_r {
						position: absolute;
					}
				
						div.asl_r.asl_w.vertical .results .item::after {
							display: block;
							position: absolute;
							bottom: 0;
							content: '';
							height: 1px;
							width: 100%;
							background: #D8D8D8;
						}
						div.asl_r.asl_w.vertical .results .item.asl_last_item::after {
							display: none;
						}
					
