    background: #F8F9FC;
    border-color: #F8F9FC;
transition:0.3s ease-in-out;

}
.endpointtile {
    background: white;
    border-radius: 12px!important;
    box-shadow: 0 14px 24px 0 rgba(191, 198, 206, 0.2);
}

