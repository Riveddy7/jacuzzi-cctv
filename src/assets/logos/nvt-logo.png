<section class="avia_codeblock_section  avia_code_block_12"  itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_codeblock '  itemprop="text" ><style >.industry-section {
 
  background-color: #f5f7fb;
}

.industry-section-inner {
  max-width: 1200px;
  margin: 0 auto;
  text-align: center;
}

.industry-section h2 {
  font-size: 1.6rem;
  margin-bottom: 1.25rem;
  color: #1e293b;
}

/* Grid */

.industry-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.1rem;
}

/* Card */

.industry-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1.2rem 0.5rem;
  border-radius: 0.85rem;
  background-color: #ffffff;
  text-decoration: none;
  color: #111827;
  box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  overflow: hidden;
  height: 155px;
}

.industry-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 22px rgba(15, 23, 42, 0.1);
}

.industry-card:focus-visible {
  outline: 3px solid #3b82f6;
  outline-offset: 4px;
}

/* Icon large by default */

.industry-icon {
    width: 300px;
    max-height: 147px;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 0.25s ease;
}

.industry-icon img {
  width: 100%;
  height: 100%;   /* ← changed from contain to 100 percent height */
  object-fit: contain;
}

/* Label anchored to bottom, hidden by default */

.industry-label {
  position: absolute;
  left: 50%;
  bottom: 16px;
  transform: translate(-50%, 18px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease, transform 0.25s ease;
  font-size: 0.85rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.035em;
  color: #111827;
  white-space: nowrap;
}

/* Hover state shrink and lift icon, show label */

.industry-card:hover .industry-icon {
  transform: scale(0.6) translateY(-10px);
}

.industry-card:hover .industry-label {
  opacity: 1;
  transform: translate(-50%, 0);
  pointer-events: auto;
}

/* Responsive layout */

@media (min-width: 500px) {
  .industry-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 800px) {
  .industry-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 1100px) {
  .industry-grid {
    grid-template-columns: repeat(5, 1fr);
  }
}

/* Hide external overlay spans */

span.image-overlay.overlay-type-extern {
  display: none !important;
}
@media (min-width: 1100px) {
  .industry-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    justify-content: center;   /* centers the leftover row */
    justify-items: center;     /* centers items inside their tracks */
  }
}</style></div></section>

</div></div></div><!-- close content main div --></div></div><div id='modernlan'  class='avia-section av-lxnknj5z-ca507b1d5e83fed7341c67fa83d89b97 main_color avia-section-default avia-no-border-styling  avia-builder-el-93  el_after_av_section  el_before_av_section  avia-bg-style-scroll av-minimum-height av-minimum-height-custom av-height-custom  container_wrap fullsize'   data-av_minimum_height_px='500'><div class='container av-section-cont-open' style='height:500px'><div class='template-page content  av-content-full alpha units'><div class='post-entry post-entry-type-page post-entry-5720'><div class='entry-content-wrapper clearfix'>
<div class='flex_column_table av-599uoda-32806b4bcab734e56736a3aa43568711 sc-av_one_full av-equal-height-column-flextable'><div  class='flex_column av-599uoda-32806b4bcab734e56736a3aa43568711 av_one_full  avia-builder-el-94  el_before_av_one_third  avia-builder-el-first  first flex_column_table_cell av-equal-height-column av-align-middle av-zero-column-padding  '     ><section  class='av_textblock_section av-lxnkolph-fe735c8a5ef49e862bb9c4e36b6b1412 '   itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_textblock av_inherit_color'  itemprop="text" ><p style="font-weight: 100; margin-bottom: -10px; line-height: 0px; text-align: center;">The Modern LAN</p>
<p style="margin-bottom: 2px; font-weight: 800; line-height: 40px; text-align: center;"><em>Rethinking Network Design for the Modern Age</em></p>
</div></section>
<div  class='hr av-4vkgrcu-d72d6d072a29311abe12550b366a5b10 hr-invisible  avia-builder-el-96  el_after_av_textblock  el_before_av_image '><span class='hr-inner '><span class="hr-inner-style"></span></span></div>
<div  class='avia-image-container av-4apkv7i-352bc7a8d58df6a38f368e3240b39dc2 av-styling- avia-align-center  avia-builder-el-97  el_after_av_hr  el_before_av_hr '   itemprop="image" itemscope="itemscope" itemtype="https://schema.org/ImageObject" ><div class="avia-image-container-inner"><div class="avia-image-overlay-wrap"><img decoding="async" fetchpriority="high" class='wp-image-27135 avia-img-lazy-loading-not-27135 avia_image ' src="https://i0.wp.com/www.nvtphybridge.com/wp-content/uploads/2018/11/0403b28e-505b-4992-8e9f-3266ede55593_fs_450.png?fit=300%2C16&ssl=1" alt='' title='{0403b28e-505b-4992-8e9f-3266ede55593}_fs_450'  height="16" width="300"  itemprop="thumbnailUrl" srcset="https://i0.wp.com/www.nvtphybridge.com/wp-content/uploads/2018/11/0403b28e-505b-4992-8e9f-3266ede55593_fs_450.png?w=450&amp;ssl=1 450w, https://i0.wp.com/www.nvtphybridge.com/wp-content/uploads/2018/11/0403b28e-505b-4992-8e9f-3266ede55593_fs_450.png?resize=300%2C16&amp;ssl=1 300w" sizes="(max-width: 300px) 100vw, 300px" /></div></div></div>
<div  class='hr av-3rdizvi-63968ddf23084258e90e5ff5aa20bc93 hr-invisible  avia-builder-el-98  el_after_av_image  el_before_av_textblock '><span class='hr-inner '><span class="hr-inner-style"></span></span></div>
<section  class='av_textblock_section av-3lkhpdq-bb28b8739ed49cc62f77b1462799b21c '   itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_textblock av_inherit_color'  itemprop="text" ><p style="text-align: center;"><strong>Developed by Frost &#038; Sullivan, The Principles of the Modern LAN define the best practices for connecting IoT (Internet of Things) endpoints in today’s Smart Buildings and Smart Cities, converging On-premise and in the Cloud.</strong></p>
</div></section></div></div><!--close column table wrapper. Autoclose: 1 --><div  class='flex_column av-368caym-52a48d8cb24009f313b014d908cdfa52 av_one_third  avia-builder-el-100  el_after_av_one_full  el_before_av_one_third  modernTiles first flex_column_div av-zero-column-padding  column-top-margin'     ><section  class='av_textblock_section av-lxnku86f-40c9ac6fbf3452233b3bf9c0b58f81da '   itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_textblock'  itemprop="text" ><p><img loading="lazy" decoding="async" class="alignnone size-full wp-image-55075" style="max-width: 60px!important;" src="https://i0.wp.com/marvel-b1-cdn.bc0a.com/f00000000248605/i0.wp.com/www.nvtphybridge.com/wp-content/uploads/2024/06/modernLANAsset-3%402x.png?resize=92%2C92&#038;ssl=1" sizes="auto, (max-width: 92px) 100vw, 92px" srcset="https://marvel-b1-cdn.bc0a.com/f00000000248605/i0.wp.com/www.nvtphybridge.com/wp-content/uploads/2024/06/modernLANAsset-3@2x.png?w=92&#038;ssl=1 92w,https://marvel-b1-cdn.bc0a.com/f00000000248605/i0.wp.com/www.nvtphybridge.com/wp-content/uploads/2024/06/modernLANAsset-3@2x.png?resize=80%2C80&#038;ssl=1 80w,https://marvel-b1-cdn.bc0a.com/f00000000248605/i0.wp.com/www.nvtphybridge.com/wp-content/uploads/2024/06/modernLANAsset-3@2x.png?resize=36%2C36&#038;ssl=1 36w" alt="" width="92" height="92" data-recalc-dims="1" /></p>
<p style="text-align: left; font-weight: 100; color: black; font-size: 16px;">Watch how Frost &#038; Sullivan developed Modern LAN principles, tailored to meet the demands of today’s interconnected and device-rich environments.</p>
<p><a id="getstarted" style="text-decoration: none!important;" href="https://www.youtube.com/watch?v=6Uyd9m2uMCQ" target="_blank" rel="noopener">Watch</a></p>
</div></section>
<section class="avia_codeblock_section  avia_code_block_13"  itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_codeblock '  itemprop="text" ><style  >#getstarted {
    padding: 10px 20px;
    border: solid 2px #1C2A38;
    background: #1C2A38;
    color: white;
    font-weight: 700;
    border-radius: 4px;
    text-decoration: none;
    transition: 0.3s ease-in-out;
    white-space: nowrap;
}
.modernTiles {
    padding: 10px 25px !important;
    border-radius: 8px !important;
}
a#getstarted {
    border-color: #31B1FF;
    background: #31B1FF;
}

a#getstarted:hover {
background: transparent;
    color: #31B1FF !important;
}
.modernTiles #getstarted {
    margin-top: 10px;
    display: inline-block;
    zoom: 0.9;
}</style ></div></section></div><div  class='flex_column av-zm8avy-a6237ae8f19862bd05936ce7236744b2 av_one_third  avia-builder-el-103  el_after_av_one_third  el_before_av_one_third  modernTiles flex_column_div av-zero-column-padding  column-top-margin'     ><section  class='av_textblock_section av-lxnlempz-b471c06ce0fa8c066ab6122c781fa735 '   itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_textblock'  itemprop="text" ><p><img loading="lazy" decoding="async" class="alignnone wp-image-55086 size-full" style="max-height: 60px !important; object-fit: contain;" src="https://i0.wp.com/www.nvtphybridge.com/wp-content/uploads/2024/06/modernLANAsset-2%402x.png?resize=78%2C92&#038;ssl=1" alt="" width="78" height="92" data-recalc-dims="1" /></p>
<p style="text-align: left; font-weight: 100; color: black; font-size: 16px;">Click here to download Frost &#038; Sullivan’s Modern LAN white paper and gain insights into the latest best practices for network design.</p>
<p><a id="getstarted" style="text-decoration: none!important;" href="https://themodernlan.org/modern-lan-form-page/" target="_blank" rel="noopener">Download Whitepaper</a></p>
</div></section></div><div  class='flex_column av-ixdn6m-2c4f9a4027a5672ad69857bbba23a4bb av_one_third  avia-builder-el-105  el_after_av_one_third  avia-builder-el-last  modernTiles flex_column_div av-zero-column-padding  column-top-margin'     ><section  class='av_textblock_section av-lxnlfd4r-11a791ebc9c0d39c9a57d57e7d2e37f1 '   itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_textblock'  itemprop="text" ><p><img loading="lazy" decoding="async" class="alignnone wp-image-55087 size-full" style="max-height: 60px !important; object-fit: contain;" src="https://i0.wp.com/www.nvtphybridge.com/wp-content/uploads/2024/06/modernLANAsset-1%402x.png?resize=74%2C92&#038;ssl=1" alt="" width="74" height="92" data-recalc-dims="1" /></p>
<p style="text-align: left; font-weight: 100; color: black; font-size: 16px;">Visit the website to learn about new network design best-practices as you deploy IP and IoT devices across the enterprise.</p>
<p><a id="getstarted" style="text-decoration: none!important;" href="https://themodernlan.org/" target="_blank" rel="noopener">Learn More</a></p>
</div></section></div>

</div></div></div><!-- close content main div --></div></div><div id='trusted'  class='avia-section av-3tchvc6-f14cc7a74c876887959a46a16e5a01d9 main_color avia-section-default avia-no-border-styling  avia-builder-el-107  el_after_av_section  el_before_av_section  avia-bg-style-scroll container_wrap fullsize'  ><div class='container av-section-cont-open' ><div class='template-page content  av-content-full alpha units'><div class='post-entry post-entry-type-page post-entry-5720'><div class='entry-content-wrapper clearfix'>
