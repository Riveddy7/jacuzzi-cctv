<div class='flex_column_table av-3xa0lp0-6e5e880bbebeb8772816bfabd17b3457 sc-av_one_half av-equal-height-column-flextable'><div  class='flex_column av-3xa0lp0-6e5e880bbebeb8772816bfabd17b3457 av_one_half  avia-builder-el-141  el_before_av_one_half  avia-builder-el-first  first flex_column_table_cell av-equal-height-column av-align-middle av-zero-column-padding  '     ><section  class='av_textblock_section av-3fou3uc-eb8e55149df2700b19a188e9687f928a '   itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_textblock av_inherit_color'  itemprop="text" ><h3 style="text-align: left; font-size: 38px; font-weight: 100; margin-bottom: 0px; line-height: 38px;"><span style="font-weight: 800;">Performance Matters</span></h3>
</div></section>
