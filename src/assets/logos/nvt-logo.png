    background: transparent!important;
color:white!important;

}

div#promoBTN span {
    font-weight: 500;
    letter-spacing: 3px;
    background: rgba(0, 0, 0, 0)!important;
    border: solid white 3px;
color:white!important;
}
div#promoBTN a {
    background: transparent!important;
color:white!important;




</style></div></section>
<section class="avia_codeblock_section  avia_code_block_1"  itemscope="itemscope" itemtype="https://schema.org/CreativeWork" ><div class='avia_codeblock '  itemprop="text" ><style >div#header_main {
    background: #F8FAFC;
    border-color: #F8FAFC;
transition:0.3s ease-in-out;
}

.endpointtile {
    padding: 0px!important;
}
